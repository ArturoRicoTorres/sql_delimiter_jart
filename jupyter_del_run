import os, glob, logging
import pandas as pd
logging.getLogger("sqlglot").setLevel(logging.ERROR)
import sql_delimiter_wtry as T          # must be the UPDATED file content

SRC_DIR       = "extracted_files_all"
CLEAN_DIR     = "delimited_clean"
REVIEW_DIR    = "review"
REPORT_PATH   = "delimiter_report.xlsx"
DIALECT       = "tsql"
MARKER        = "[AUTOMATED DELIMITER]"
TERMINATE_ALL = True

SEND_ALL_TO_CLEAN = True
CONSERVATIVE      = False
N                 = None

os.makedirs(CLEAN_DIR, exist_ok=True)
os.makedirs(REVIEW_DIR, exist_ok=True)
files = sorted(glob.glob(os.path.join(SRC_DIR, "*.sql")))[:N]
print(len(files), "files to process")

rows = []
for i, path in enumerate(files, 1):
    sql = open(path, encoding="utf-8", errors="replace").read()
    ins, _ = T.annotate(sql, DIALECT, terminate_all=TERMINATE_ALL, conservative=CONSERVATIVE)
    pre    = T.review(sql, ins, verbose=False)
    flags  = T.flagged_cuts(ins, sql, verbose=False)
    fixed  = T.apply(sql, ins, annotate_marker=True, marker=MARKER)
    mid    = T.check_midline_cut(fixed, marker=MARKER, verbose=False)
    NEEDLE        = "/* " + MARKER + " */"
    automated_delims = fixed.count(NEEDLE)     # delimiters actually written by the tool

    needs_review = bool(pre) or bool(flags) or bool(mid)
    dest = CLEAN_DIR if SEND_ALL_TO_CLEAN else (REVIEW_DIR if needs_review else CLEAN_DIR)
    out_path = os.path.join(dest, os.path.basename(path))
    with open(out_path, "w", encoding="utf-8", newline="") as f:
        f.write(fixed)

    total_lines = len(sql.splitlines())
    code_lines  = sum(1 for ln in sql.splitlines() if ln.strip())
    density     = round(automated_delims / code_lines * 100, 1) if code_lines else 0.0

    rows.append({
        "file": os.path.basename(path),
        "total_lines": total_lines,
        "code_lines": code_lines,
        "automated_delimiters": automated_delims,        # marker-counted, ground truth
        "boundaries_detected": sum(1 for x in ins if not x.flagged),
        "preexisting_delims_skipped": sum(1 for x in ins if not x.flagged) - automated_delims,
        "delims_per_100_code_lines": density,
        "flagged_not_applied": len(flags),
        "op_position_warnings": len(pre),
        "midline_cut_warnings": len(mid),
        "needs_review": needs_review,
        "destination": dest,
    })
    print(f"[{i}/{len(files)}] +{n_applied:3d} delims  {code_lines:4d} code lines  "
          f"({density:5.1f}/100)  -> {out_path}")

# --- build the report ---
df = pd.DataFrame(rows).sort_values("delims_per_100_code_lines", ascending=False)

totals = {
    "file": f"TOTAL ({len(df)} files)",
    "total_lines": df["total_lines"].sum(),
    "code_lines": df["code_lines"].sum(),
    "delimiters_applied": df["delimiters_applied"].sum(),
    "delims_per_100_code_lines": round(
        df["delimiters_applied"].sum() / df["code_lines"].sum() * 100, 1
    ) if df["code_lines"].sum() else 0.0,
    "flagged_not_applied": df["flagged_not_applied"].sum(),
    "op_position_warnings": df["op_position_warnings"].sum(),
    "midline_cut_warnings": df["midline_cut_warnings"].sum(),
    "needs_review": int(df["needs_review"].sum()),
    "destination": "",
}
df_out = pd.concat([df, pd.DataFrame([totals])], ignore_index=True)

with pd.ExcelWriter(REPORT_PATH, engine="openpyxl") as xl:
    df_out.to_excel(xl, index=False, sheet_name="delimiters")
    ws = xl.sheets["delimiters"]
    ws.freeze_panes = "A2"                                  # keep header visible
    for col in ws.columns:                                  # rough auto-width
        width = max(len(str(c.value)) if c.value is not None else 0 for c in col) + 2
        ws.column_dimensions[col[0].column_letter].width = min(width, 40)

print(f"\nReport written to '{REPORT_PATH}'  ({len(df)} files).")
print(f"Total delimiters: {df['delimiters_applied'].sum()}  |  "
      f"overall density: {totals['delims_per_100_code_lines']}/100 code lines")
